# ⚠️ IMPORTANTE: NO SUBIR ESTE ARCHIVO CON VALORES REALES A GIT
# Copiar a .env y configurar con valores reales

# JWT Configuration
JWT_KEY=GENERAR-CLAVE-ALEATORIA-SEGURA-DE-64-CARACTERES-MINIMO
JWT_ISSUER=FinancialCopilot
JWT_AUDIENCE=FinancialCopilotUsers

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=financialcopilot
DATABASE_USER=postgres
DATABASE_PASSWORD=CAMBIAR_PASSWORD_SEGURO
DATABASE_SSL_MODE=Require

# Email (Gmail SMTP)
# Para Gmail: activar "Verificación en 2 pasos" y generar una "App Password"
# en https://myaccount.google.com/apppasswords
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=ctslabscartagena@gmail.com
EMAIL_SMTP_PASSWORD=xxxx xxxx xxxx xxxx   # App Password de 16 caracteres
EMAIL_FROM_NAME=FINNOVA
EMAIL_FROM_EMAIL=ctslabscartagena@gmail.com

# Admin Bootstrap (usar una sola vez para crear el primer admin)
ADMIN_BOOTSTRAP_KEY=GENERAR-CLAVE-SECRETA-BOOTSTRAP

# CORS
CORS_ORIGINS=http://localhost:3000,https://tudominio.com

# Environment
ASPNETCORE_ENVIRONMENT=Production

# AI Engine
AI_ENGINE_URL=http://localhost:8000
AI_ENGINE_API_KEY=GENERAR-CLAVE-ALEATORIA-PARA-AI-ENGINE
